    "import numpy as np\n",
    "arr=np.arange(1,13)\n",
    "print(arr)\n",
    "arr1=np.split(arr,3)\n",
    "print(arr1)\n",
    "arr2=[np.delete(i,-1)for i in arr1]\n",
    "print(arr2)\n",
    "arr3=np.concatenate(arr2)\n",
    "print(arr3)"
